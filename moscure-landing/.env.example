# ─────────────────────────────────────────────────────────────────
# MOSCURE .env.example — copy to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────

# ── Supabase (frontend + server) ──────────────────────────────────
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...         # Safe to expose — public anon key

# ── Supabase (server-side ONLY — never in frontend) ───────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...      # KEEP SECRET — bypasses RLS

# ── Razorpay — Toggle mode with RAZORPAY_MODE ─────────────────────
RAZORPAY_MODE=test                         # Change to 'live' for production

# Test Keys (from Razorpay Dashboard → Settings → API Keys → Test Mode)
VITE_RAZORPAY_TEST_KEY_ID=rzp_test_xxxx    # Safe to expose
RAZORPAY_TEST_KEY_ID=rzp_test_xxxx
RAZORPAY_TEST_KEY_SECRET=xxxx              # KEEP SECRET

# Live Keys (from Razorpay Dashboard → Settings → API Keys → Live Mode)
VITE_RAZORPAY_LIVE_KEY_ID=rzp_live_xxxx   # Safe to expose
RAZORPAY_LIVE_KEY_ID=rzp_live_xxxx
RAZORPAY_LIVE_KEY_SECRET=xxxx             # KEEP SECRET

# Active key sent to frontend (set based on RAZORPAY_MODE)
# In your Vite build, set VITE_RAZORPAY_KEY_ID to match the mode:
VITE_RAZORPAY_KEY_ID=rzp_test_xxxx        # Update to live key when going live

# ── Admin Panel ────────────────────────────────────────────────────
VITE_ADMIN_PASSWORD=your_strong_admin_password
ADMIN_PASSWORD=your_strong_admin_password  # Must match VITE_ADMIN_PASSWORD

# ── Server Config ──────────────────────────────────────────────────
PORT=3001
ALLOWED_ORIGINS=https://www.moscure.com,https://moscure.com

# ── Email (Resend.com — optional, for order confirmation emails) ───
# RESEND_API_KEY=re_xxxx
# FROM_EMAIL=orders@moscure.com
